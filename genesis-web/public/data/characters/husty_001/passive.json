{
  "type": "passive",
  "id": "husty_001_precise_calibration",
  "name": "Precise Calibration",
  "description": "After spending 60 AP, Husty's precision sharpens: gains +80 Precision for 4 turns. Resets on proc.",
  "effects": [
    {
      "when": { "event": "onApSpent" },
      "condition": {
        "all": [
          { "apAccumGte": 60 },
          { "not": { "selfHasStatus": "husty_001_precision_buff" } }
        ]
      },
      "type": "applyStatus",
      "target": "self",
      "status": "husty_001_precision_buff"
    },
    {
      "when": { "event": "onApSpent" },
      "condition": { "apAccumGte": 60 },
      "type": "resetApAccum"
    }
  ]
}
