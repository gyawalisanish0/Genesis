  "hugo_001_hyper_sense": [
    { "type": "flash", "figure": "acting", "colour": "var(--accent-silver)" },
    { "type": "aura", "figure": "acting", "show": true },
    { "type": "wait", "ms": 350 },
    { "type": "aura", "figure": "acting", "show": false },
    { "type": "feedback" }
