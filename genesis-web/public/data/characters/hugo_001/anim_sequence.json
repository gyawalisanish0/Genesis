    { "type": "cameraShake", "duration": 220, "intensity": 0.005 },
    { "type": "parallel", "phases": [
      { "type": "damageNumber" },
      { "type": "feedback" }
    ]}
  ],

  "hugo_001_shelling_point": [
    { "type": "playAnim", "figure": "acting", "stateKey": "idle" },
    { "type": "parallel", "phases": [
