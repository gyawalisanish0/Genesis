#: kivy 2.3.0
# RosterScreen + CharacterCard

# ── Character card ────────────────────────────────────────────────────────────

<CharacterCard>:
    orientation: 'vertical'
    size_hint_y: None
    height: dp(200)
    padding: dp(6)
    spacing: dp(4)
    canvas.before:
        # Card background
        Color:
            rgba: (0.110, 0.106, 0.149, 1)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(10)]
        # Rarity border
        Color:
            rgba: root.rarity_color
        Line:
            rounded_rectangle: (self.x + 1, self.y + 1, self.width - 2, self.height - 2, dp(10))
            width: dp(1.5)

    # Portrait placeholder
    Widget:
        size_hint_y: None
        height: dp(108)
        canvas:
            Color:
                rgba: (0.082, 0.078, 0.114, 1)
            RoundedRectangle:
                pos: self.x + dp(8), self.y
                size: self.width - dp(16), self.height
                radius: [dp(8)]
            Color:
                rgba: root.rarity_color[0], root.rarity_color[1], root.rarity_color[2], 0.25
            Ellipse:
                pos: self.center_x - dp(28), self.y + dp(30)
                size: dp(56), dp(56)
            Color:
                rgba: root.rarity_color[0], root.rarity_color[1], root.rarity_color[2], 0.15
            Ellipse:
                pos: self.center_x - dp(20), self.y + dp(8)
                size: dp(40), dp(40)

    # Character name
    Label:
        text: root.char_name
        font_size: sp(13)
        bold: True
        color: (0.945, 0.941, 1.0, 1)
        size_hint_y: None
        height: dp(22)
        halign: 'center'
        valign: 'middle'
        text_size: self.size
        shorten: True
        shorten_from: 'right'

    # Class + rarity row
    BoxLayout:
        size_hint_y: None
        height: dp(18)
        spacing: dp(4)
        Label:
            text: root.char_class
            font_size: sp(11)
            color: (0.608, 0.557, 0.769, 1)
            halign: 'left'
            valign: 'middle'
            text_size: self.size
        Label:
            text: root.rarity_label
            font_size: sp(11)
            color: root.rarity_color
            size_hint_x: None
            width: dp(56)
            halign: 'right'
            valign: 'middle'
            text_size: self.size

    # HP stat
    Label:
        text: f'HP  {root.char_hp}'
        font_size: sp(11)
        color: (0.361, 0.329, 0.502, 1)
        size_hint_y: None
        height: dp(16)
        halign: 'center'
        valign: 'middle'
        text_size: self.size


# ── Roster screen ─────────────────────────────────────────────────────────────

<RosterScreen>:
    BoxLayout:
        orientation: 'vertical'
        canvas.before:
            Color:
                rgba: (0.067, 0.063, 0.094, 1)
            Rectangle:
                pos: self.pos
                size: self.size

        # ── Header ──────────────────────────────────────────────────────────
        BoxLayout:
            size_hint_y: None
            height: dp(56)
            canvas.before:
                Color:
                    rgba: (0.082, 0.078, 0.114, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size
            Button:
                text: '\u2190'
                size_hint_x: None
                width: dp(56)
                font_size: sp(20)
                color: (0.945, 0.941, 1.0, 1)
                background_color: (0, 0, 0, 0)
                on_release: root._on_back()
            Label:
                text: 'ROSTER'
                font_size: sp(16)
                bold: True
                color: (0.945, 0.941, 1.0, 1)
                halign: 'left'
                valign: 'middle'
                text_size: self.size
            Label:
                id: count_label
                text: ''
                font_size: sp(11)
                color: (0.361, 0.329, 0.502, 1)
                size_hint_x: None
                width: dp(96)
                halign: 'right'
                valign: 'middle'
                text_size: self.size
                padding: dp(8), 0

        # ── Class filter tabs ────────────────────────────────────────────────
        ScrollView:
            size_hint_y: None
            height: dp(44)
            do_scroll_y: False
            bar_width: 0
            canvas.before:
                Color:
                    rgba: (0.082, 0.078, 0.114, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size
            BoxLayout:
                id: class_filter_row
                orientation: 'horizontal'
                size_hint_x: None
                width: dp(144)
                spacing: dp(2)
                padding: dp(8), dp(4)

        # ── Rarity chips ─────────────────────────────────────────────────────
        ScrollView:
            size_hint_y: None
            height: dp(40)
            do_scroll_y: False
            bar_width: 0
            canvas.before:
                Color:
                    rgba: (0.082, 0.078, 0.114, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size
            BoxLayout:
                id: rarity_filter_row
                orientation: 'horizontal'
                size_hint_x: None
                width: dp(112)
                spacing: dp(2)
                padding: dp(8), dp(4)

        # ── Character grid ───────────────────────────────────────────────────
        ScrollView:
            do_scroll_x: False
            GridLayout:
                id: char_grid
                cols: 2
                size_hint_y: None
                height: self.minimum_height
                padding: dp(8)
                spacing: dp(8)

        # Safe-area bottom buffer
        Widget:
            size_hint_y: None
            height: dp(48)
