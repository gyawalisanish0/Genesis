#: kivy 2.3.0
# StubScreen — Coming Soon placeholder

<StubScreen>:
    BoxLayout:
        orientation: 'vertical'
        canvas.before:
            Color:
                rgba: (0.067, 0.063, 0.094, 1)
            Rectangle:
                pos: self.pos
                size: self.size

        # Header
        BoxLayout:
            size_hint_y: None
            height: dp(56)
            canvas.before:
                Color:
                    rgba: (0.082, 0.078, 0.114, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size
            Button:
                text: '\u2190'
                size_hint_x: None
                width: dp(56)
                font_size: sp(20)
                color: (0.945, 0.941, 1.0, 1)
                background_color: (0, 0, 0, 0)
                on_release: root._on_back()
            Label:
                text: root.title_text
                font_size: sp(16)
                bold: True
                color: (0.945, 0.941, 1.0, 1)
                halign: 'left'
                valign: 'middle'
                text_size: self.size

        # Body
        BoxLayout:
            orientation: 'vertical'
            padding: dp(32)
            spacing: dp(16)

            Widget:
                size_hint_y: 1

            Label:
                text: root.title_text
                font_size: sp(28)
                bold: True
                color: (0.945, 0.941, 1.0, 1)
                halign: 'center'
                size_hint_y: None
                height: dp(48)

            Label:
                text: 'Coming Soon'
                font_size: sp(15)
                color: (0.608, 0.557, 0.769, 1)
                halign: 'center'
                size_hint_y: None
                height: dp(28)

            Widget:
                size_hint_y: 1

            Button:
                text: '\u2190 Back'
                size_hint: None, None
                size: dp(160), dp(48)
                pos_hint: {'center_x': 0.5}
                font_size: sp(14)
                color: (0.945, 0.941, 1.0, 1)
                background_normal: ''
                background_color: (0.141, 0.137, 0.188, 1)
                on_release: root._on_back()

            Widget:
                size_hint_y: None
                height: dp(48)
