#: kivy 2.3.0
# PreBattleScreen + ModeCard + CharacterSlot + RosterPickCard

# ── Mode card (step 1) ────────────────────────────────────────────────────────

<ModeCard>:
    orientation: 'vertical'
    size_hint_y: None
    height: dp(96)
    padding: dp(12), dp(10)
    spacing: dp(4)
    canvas.before:
        Color:
            rgba: (0.545, 0.361, 0.965, 0.18) if root.is_selected else (0.110, 0.106, 0.149, 1)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(10)]
        Color:
            rgba: (0.545, 0.361, 0.965, 1) if root.is_selected else (0.141, 0.137, 0.188, 1)
        Line:
            rounded_rectangle: (self.x + 1, self.y + 1, self.width - 2, self.height - 2, dp(10))
            width: 1.5
    Label:
        text: root.mode_name
        font_size: sp(15)
        bold: True
        color: (0.945, 0.941, 1.0, 1)
        size_hint_y: None
        height: dp(28)
        halign: 'left'
        valign: 'middle'
        text_size: self.size
    Label:
        text: root.mode_desc
        font_size: sp(12)
        color: (0.608, 0.557, 0.769, 1)
        halign: 'left'
        valign: 'top'
        text_size: self.size


# ── Character slot (step 2 — top row) ────────────────────────────────────────

<CharacterSlot>:
    orientation: 'vertical'
    padding: dp(6)
    canvas.before:
        Color:
            rgba: (0.545, 0.361, 0.965, 0.15) if root.is_filled else (0.082, 0.078, 0.114, 1)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(8)]
        Color:
            rgba: root.rarity_color if root.is_filled else (0.200, 0.196, 0.259, 1)
        Line:
            rounded_rectangle: (self.x + 1, self.y + 1, self.width - 2, self.height - 2, dp(8))
            width: 1.5
    Label:
        text: root.slot_label
        font_size: sp(12) if root.is_filled else sp(22)
        bold: root.is_filled
        color: (0.945, 0.941, 1.0, 1) if root.is_filled else (0.361, 0.329, 0.502, 1)
        halign: 'center'
        valign: 'middle'
        text_size: self.size
        shorten: True
        shorten_from: 'right'
    Label:
        text: 'tap to remove' if root.is_filled else ''
        font_size: sp(10)
        color: (0.361, 0.329, 0.502, 1)
        size_hint_y: None
        height: dp(14)
        halign: 'center'


# ── Roster pick card (step 2 — picker grid) ───────────────────────────────────

<RosterPickCard>:
    orientation: 'horizontal'
    size_hint_y: None
    height: dp(64)
    padding: dp(8)
    spacing: dp(10)
    canvas.before:
        Color:
            rgba: (0.545, 0.361, 0.965, 0.15) if root.in_team else (0.110, 0.106, 0.149, 1)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(8)]
        Color:
            rgba: (0.545, 0.361, 0.965, 1) if root.in_team else (0.141, 0.137, 0.188, 1)
        Line:
            rounded_rectangle: (self.x + 1, self.y + 1, self.width - 2, self.height - 2, dp(8))
            width: 1.2

    # Rarity dot / portrait hint
    Widget:
        size_hint_x: None
        width: dp(40)
        canvas:
            Color:
                rgba: root.rarity_color
            Ellipse:
                pos: self.x + dp(4), self.y + dp(4)
                size: dp(32), dp(32)

    # Name + class
    BoxLayout:
        orientation: 'vertical'
        spacing: dp(2)
        Label:
            text: root.char_name
            font_size: sp(13)
            bold: True
            color: (0.945, 0.941, 1.0, 1)
            halign: 'left'
            valign: 'middle'
            text_size: self.size
            shorten: True
            shorten_from: 'right'
        Label:
            text: root.char_class
            font_size: sp(11)
            color: (0.608, 0.557, 0.769, 1)
            halign: 'left'
            valign: 'middle'
            text_size: self.size

    # Check indicator
    Label:
        text: '\u2713' if root.in_team else ''
        font_size: sp(16)
        color: (0.063, 0.725, 0.506, 1)
        size_hint_x: None
        width: dp(24)
        halign: 'center'
        valign: 'middle'


# ── Pre-battle screen shell ───────────────────────────────────────────────────

<PreBattleScreen>:
    BoxLayout:
        orientation: 'vertical'
        canvas.before:
            Color:
                rgba: (0.067, 0.063, 0.094, 1)
            Rectangle:
                pos: self.pos
                size: self.size

        # ── Header ──────────────────────────────────────────────────────────
        BoxLayout:
            size_hint_y: None
            height: dp(56)
            canvas.before:
                Color:
                    rgba: (0.082, 0.078, 0.114, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size

            # Back button
            Button:
                text: '\u2190'
                size_hint_x: None
                width: dp(56)
                font_size: sp(20)
                color: (0.945, 0.941, 1.0, 1)
                background_color: (0, 0, 0, 0)
                on_release: root._on_back()

            # Step label
            Label:
                id: step_label
                text: 'SELECT MODE'
                font_size: sp(13)
                bold: True
                color: (0.945, 0.941, 1.0, 1)
                halign: 'center'
                valign: 'middle'

            # Step dots
            BoxLayout:
                size_hint_x: None
                width: dp(56)
                spacing: dp(6)
                padding: dp(8), 0
                Label:
                    id: dot_1
                    text: '\u25cf'
                    font_size: sp(10)
                    color: (0.545, 0.361, 0.965, 1)
                    opacity: 1.0
                Label:
                    id: dot_2
                    text: '\u25cf'
                    font_size: sp(10)
                    color: (0.545, 0.361, 0.965, 1)
                    opacity: 0.3
                Label:
                    id: dot_3
                    text: '\u25cf'
                    font_size: sp(10)
                    color: (0.545, 0.361, 0.965, 1)
                    opacity: 0.3

        # ── Step content ─────────────────────────────────────────────────────
        BoxLayout:
            id: step_container
            orientation: 'vertical'
            padding: dp(8), dp(8)
            spacing: dp(0)

        # ── Footer — continue button ─────────────────────────────────────────
        BoxLayout:
            size_hint_y: None
            height: dp(64)
            padding: dp(16), dp(8)
            canvas.before:
                Color:
                    rgba: (0.082, 0.078, 0.114, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size
            Button:
                id: continue_btn
                text: 'CONTINUE  \u2192'
                font_size: sp(15)
                bold: True
                color: (0.945, 0.941, 1.0, 1)
                background_normal: ''
                background_color: (0, 0, 0, 0)
                on_release: root._on_continue()
                canvas.before:
                    Color:
                        rgba: (0.545, 0.361, 0.965, 1)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(10)]

        # Safe-area bottom buffer
        Widget:
            size_hint_y: None
            height: dp(48)
