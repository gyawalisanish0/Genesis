#: kivy 2.3.0
# SplashScreen — app launch loading screen

<SplashScreen>:
    BoxLayout:
        orientation: 'vertical'
        canvas.before:
            Color:
                rgba: (0.067, 0.063, 0.094, 1)
            Rectangle:
                pos: self.pos
                size: self.size

        # Top spacer — pushes content toward vertical centre
        Widget:
            size_hint_y: None
            height: dp(160)

        # Logo placeholder — filled circle
        Widget:
            size_hint: None, None
            size: dp(120), dp(120)
            pos_hint: {'center_x': 0.5}
            canvas:
                Color:
                    rgba: (0.545, 0.361, 0.965, 1)
                Ellipse:
                    pos: self.pos
                    size: self.size
                Color:
                    rgba: (0.067, 0.063, 0.094, 1)
                Ellipse:
                    pos: self.x + dp(16), self.y + dp(16)
                    size: dp(88), dp(88)
                Color:
                    rgba: (0.945, 0.941, 1.0, 1)
                Ellipse:
                    pos: self.x + dp(36), self.y + dp(36)
                    size: dp(48), dp(48)

        Widget:
            size_hint_y: None
            height: dp(24)

        # Title
        Label:
            text: 'GENESIS'
            font_size: sp(36)
            bold: True
            color: (0.945, 0.941, 1.0, 1)
            size_hint_y: None
            height: dp(56)
            halign: 'center'

        # Tagline
        Label:
            text: 'Turn-based tactical combat'
            font_size: sp(13)
            color: (0.608, 0.557, 0.769, 1)
            size_hint_y: None
            height: dp(24)
            halign: 'center'

        # Flexible spacer
        Widget:
            size_hint_y: 1

        # Progress bar track + fill
        AnchorLayout:
            size_hint_y: None
            height: dp(24)
            anchor_x: 'center'
            anchor_y: 'center'
            BoxLayout:
                id: progress_track
                size_hint: None, None
                size: dp(220), dp(6)
                canvas.before:
                    Color:
                        rgba: (0.141, 0.137, 0.188, 1)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(3)]
                Widget:
                    id: progress_fill
                    size_hint: None, 1
                    width: 0
                    canvas:
                        Color:
                            rgba: (0.545, 0.361, 0.965, 1)
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(3)]

        Widget:
            size_hint_y: None
            height: dp(12)

        # Loading label — id used by SplashScreen._show_error() on crash
        Label:
            id: loading_label
            text: 'Loading...'
            font_size: sp(11)
            color: (0.361, 0.329, 0.502, 1)
            size_hint_y: None
            height: dp(20)
            halign: 'center'

        # Bottom spacer (safe-area buffer)
        Widget:
            size_hint_y: None
            height: dp(80)
