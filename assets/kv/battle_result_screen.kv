#: kivy 2.3.0
# BattleResultScreen — post-battle summary

<BattleResultScreen>:
    BoxLayout:
        orientation: 'vertical'
        canvas.before:
            Color:
                rgba: (0.067, 0.063, 0.094, 1)
            Rectangle:
                pos: self.pos
                size: self.size

        # ── Victory / Defeat banner ──────────────────────────────────────────
        BoxLayout:
            id: banner_box
            orientation: 'vertical'
            size_hint_y: None
            height: dp(128)
            padding: dp(16), dp(16)
            spacing: dp(4)

            Label:
                id: result_title
                text: '\u2605 VICTORY \u2605'
                font_size: sp(30)
                bold: True
                color: (0.961, 0.620, 0.043, 1)
                halign: 'center'
                valign: 'bottom'
                size_hint_y: None
                height: dp(52)

            Label:
                id: result_sub
                text: 'Battle Complete'
                font_size: sp(13)
                color: (0.945, 0.941, 1.0, 0.7)
                halign: 'center'
                size_hint_y: None
                height: dp(24)

        # ── Scrollable body ──────────────────────────────────────────────────
        ScrollView:
            do_scroll_x: False
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                padding: dp(16), dp(8)
                spacing: dp(12)

                # Rewards card
                BoxLayout:
                    size_hint_y: None
                    height: dp(64)
                    padding: dp(16), dp(8)
                    spacing: dp(8)
                    canvas.before:
                        Color:
                            rgba: (0.110, 0.106, 0.149, 1)
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(10)]
                    Label:
                        text: 'XP GAINED'
                        font_size: sp(12)
                        bold: True
                        color: (0.608, 0.557, 0.769, 1)
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size
                    Label:
                        id: xp_label
                        text: '+0 XP'
                        font_size: sp(20)
                        bold: True
                        color: (0.961, 0.620, 0.043, 1)
                        halign: 'right'
                        valign: 'middle'
                        text_size: self.size

                # Team summary header
                Label:
                    text: 'TEAM SUMMARY'
                    font_size: sp(11)
                    bold: True
                    color: (0.545, 0.361, 0.965, 1)
                    size_hint_y: None
                    height: dp(28)
                    halign: 'left'
                    valign: 'bottom'
                    text_size: self.size

                # Unit rows (populated from Python)
                BoxLayout:
                    id: unit_rows
                    orientation: 'vertical'
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: dp(6)

                # Battle stats header
                Label:
                    text: 'BATTLE STATS'
                    font_size: sp(11)
                    bold: True
                    color: (0.545, 0.361, 0.965, 1)
                    size_hint_y: None
                    height: dp(36)
                    halign: 'left'
                    valign: 'bottom'
                    text_size: self.size

                # Stats grid (2-col label / value pairs)
                GridLayout:
                    id: stats_grid
                    cols: 2
                    size_hint_y: None
                    height: dp(72)
                    spacing: dp(4), dp(8)
                    padding: dp(8), 0

                # Bottom padding before buttons
                Widget:
                    size_hint_y: None
                    height: dp(8)

        # ── CTA buttons ──────────────────────────────────────────────────────
        BoxLayout:
            size_hint_y: None
            height: dp(72)
            padding: dp(16), dp(8)
            spacing: dp(10)
            canvas.before:
                Color:
                    rgba: (0.082, 0.078, 0.114, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size

            # PLAY AGAIN
            Button:
                text: 'PLAY AGAIN'
                font_size: sp(14)
                bold: True
                color: (0.945, 0.941, 1.0, 1)
                background_normal: ''
                background_color: (0, 0, 0, 0)
                on_release: root._on_play_again()
                canvas.before:
                    Color:
                        rgba: (0.545, 0.361, 0.965, 1)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(10)]

            # MAIN MENU
            Button:
                text: 'MAIN MENU'
                font_size: sp(14)
                color: (0.608, 0.557, 0.769, 1)
                background_normal: ''
                background_color: (0, 0, 0, 0)
                on_release: root._on_main_menu()
                canvas.before:
                    Color:
                        rgba: (0.141, 0.137, 0.188, 1)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(10)]

        # Safe-area bottom buffer
        Widget:
            size_hint_y: None
            height: dp(48)
